# Supabase (lấy từ https://supabase.com/dashboard → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxx

# Database — Dashboard → nút "Connect" → URI. LUÔN dùng pooler hostname (aws-*.pooler.supabase.com):
#   - Local (db:push, dev):  Session pooler, port 5432
#   - Vercel (production):   Transaction pooler, port 6543
# ĐỪNG dùng "Direct connection" db.<ref>.supabase.co — chỉ có IPv6, dễ lỗi getaddrinfo ENOTFOUND
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Service role key (chỉ dùng server-side, đừng commit) — Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxx

# AI attachments (server-side)
# AI_ATTACHMENT_PROVIDER=openai enables OCR/vision parsing. Leave OPENAI_API_KEY blank to keep the safe fallback.
AI_ATTACHMENTS_BUCKET=ai-attachments
AI_ATTACHMENT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
