# Supabase (lấy từ https://supabase.com/dashboard → project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxx

# Database — Dashboard → nút "Connect" → URI. LUÔN dùng pooler hostname (aws-*.pooler.supabase.com):
#   - Local (db:push, dev):  Session pooler, port 5432
#   - Vercel (production):   Transaction pooler, port 6543
# ĐỪNG dùng "Direct connection" db.<ref>.supabase.co — chỉ có IPv6, dễ lỗi getaddrinfo ENOTFOUND
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Service role key (chỉ dùng server-side, đừng commit) — Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxx

# Signs short-lived cashier context tokens used by mobile quick switch.
# Generate a random value with at least 32 characters and keep it server-side.
MOBILE_CASHIER_CONTEXT_SECRET=replace-with-at-least-32-random-characters

# AI provider settings are configured in the app UI:
# Settings > AI. API keys are stored server-side and are not read from env.

# SePay webhook/auth config (server-side only)
# Settings > Payments chỉ cần thêm tài khoản ngân hàng; secret/API key đặt ở env theo deployment.
SEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SEPAY_API_KEY=

# Hosted payment gateways (server-side only). A method remains unavailable to
# mobile until its complete credential set and a public HTTPS callback base are present.
# Use "sandbox" during SIT; switch to "production" only after provider certification.
PAYMENT_GATEWAY_ENV=sandbox
PAYMENT_CALLBACK_BASE_URL=https://pos.example.com
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# Data-only FCM background notifications. Store the complete Firebase service
# account JSON as one server-side environment value; never expose it to Flutter.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Protects the scheduled /api/cron/notifications invocation.
NOTIFICATION_CRON_SECRET=replace-with-at-least-32-random-characters

# Protects scheduled e-invoice retry processing. CRON_SECRET is accepted as a
# deployment-level fallback, but a separate secret is preferred.
EINVOICE_CRON_SECRET=replace-with-at-least-32-random-characters

# Production e-invoice bridge (server-side only). The selected provider must
# exactly match Settings > Tax & E-Invoice. The bridge URL must be public HTTPS
# and implement the signed LumaPOS bridge contract documented in the mobile API
# contract. API keys and HMAC secrets must never be exposed to Flutter.
EINVOICE_BRIDGE_PROVIDER=VNPT
EINVOICE_BRIDGE_URL=https://einvoice-bridge.example.com/v1/issue
EINVOICE_BRIDGE_API_KEY=
EINVOICE_BRIDGE_HMAC_SECRET=replace-with-at-least-32-random-characters
